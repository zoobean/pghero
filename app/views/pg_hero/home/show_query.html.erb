<div class="card card-body mb-3">
  <pre><code class="query-code"><%= @query %></code></pre>
  <%= javascript_tag nonce: true do %>
    highlightQueries()
  <% end %>

  <% if @explain_enabled && @explainable_query %>
    <p>
      <%= button_to "Explain", explain_path, params: {query: @explainable_query}, form: {target: "_blank"}, class: "btn btn-primary" %>
    </p>
  <% end %>

  <% if @origins && @origins.keys.select { |k| k.length > 0 }.any? %>
    <table class="table table-vcenter origins-table">
      <thead>
        <tr>
          <th colspan="2">
            <div class="float-end">Approx. Time</div>
            Origin
          </th>
        </tr>
      </thead>
      <tbody>
        <% @origins.sort_by { |o, c| [-c, o.to_s] }.each do |origin, count| %>
          <tr>
            <td class="origin">
              <% if origin.length > 0 %>
                <%= origin %>
              <% else %>
                <span class="text-muted">Unknown</span>
              <% end %>
            </td>
            <td class="origin-pct">
              <% pct = (100.0 * count / @total_count).round %>
              <% if pct == 0 %>
                &lt; 1%
              <% else %>
                <%= pct %>%
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>

  <!-- chart -->
  <% if @chart_data %>
    <% if @query_trend && @query_trend[:change_pct] %>
      <div class="alert alert-<%= @query_trend[:direction] == :regressing ? "warning" : "success" %>">
        14-day trend:
        <span class="<%= pghero_query_trend_class(@query_trend) %>"><%= pghero_query_trend_label(@query_trend) %></span>
        <span class="small text-secondary ms-1">
          <%= number_with_precision(@query_trend[:baseline_average_time].to_f, precision: 1) %> ms baseline
          to
          <%= number_with_precision(@query_trend[:recent_average_time].to_f, precision: 1) %> ms recent
        </span>
      </div>
    <% end %>

    <h1><%= @trend_days %>-Day Total Time <small>ms</small></h1>
    <div id="chart-1" class="chart">Loading...</div>
    <%= javascript_tag nonce: true do %>
      new Chartkick.LineChart("chart-1", <%= pghero_js_value(@chart_data) %>, {colors: ["#5bc0de"], legend: false, library: {plugins: {tooltip: {intersect: false, mode: "index"}}}})
    <% end %>

    <h1><%= @trend_days %>-Day Average Time <small>ms</small></h1>
    <div id="chart-2" class="chart">Loading...</div>
    <%= javascript_tag nonce: true do %>
      new Chartkick.LineChart("chart-2", <%= pghero_js_value(@chart2_data) %>, {colors: ["#5bc0de"], legend: false, library: {plugins: {tooltip: {intersect: false, mode: "index"}}}})
    <% end %>

    <h1><%= @trend_days %>-Day Calls</h1>
    <div id="chart-3" class="chart">Loading...</div>
    <%= javascript_tag nonce: true do %>
      new Chartkick.LineChart("chart-3", <%= pghero_js_value(@chart3_data) %>, {colors: ["#5bc0de"], legend: false, library: {plugins: {tooltip: {intersect: false, mode: "index"}}}})
    <% end %>

    <h1>Release Correlation</h1>
    <% if @release_correlation && @release_correlation[:enabled] %>
      <% if (release = @release_correlation[:correlated_release]) %>
        <div class="alert alert-warning">
          Likely regression followed
          <%= link_to(release[:name].presence || release[:tag_name], release[:url], target: "_blank", rel: "noopener") %>
          <span class="small text-secondary ms-1"><%= pghero_formatted_date_time(release[:published_at]) %></span>
        </div>
      <% elsif @release_correlation[:releases].any? %>
        <p>No clear release-aligned regression detected in the last <%= @trend_days %> days.</p>
      <% else %>
        <p>No recent published releases found in the last <%= @trend_days %> days.</p>
      <% end %>

      <% if @release_correlation[:releases].any? %>
        <table class="table card-table table-vcenter">
          <thead>
            <tr>
              <th style="width: 33%">Release</th>
              <th style="width: 33%">Published</th>
              <th style="width: 33%">Commit</th>
            </tr>
          </thead>
          <tbody>
            <% @release_correlation[:releases].reverse_each do |release| %>
              <tr>
                <td>
                  <%= link_to(release[:name].presence || release[:tag_name], release[:url], target: "_blank", rel: "noopener") %>
                </td>
                <td><%= pghero_formatted_date_time(release[:published_at]) %></td>
                <td>
                  <% if (commit_url = pghero_github_commit_url(@database.github_repo, release[:sha])) %>
                    <%= link_to release[:sha].to_s.first(7), commit_url, target: "_blank", rel: "noopener" %>
                  <% else %>
                    <%= release[:sha] %>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% end %>
    <% else %>
      <p>
        Configure <code>github_repo</code> and either <code>github_token</code> or <code>github_app_id</code> plus a private key to correlate regressions with GitHub releases.
      </p>
    <% end %>
  <% else %>
    <p>
      Enable
      <%= link_to "historical query stats", "https://github.com/ankane/pghero", target: "_blank" %>
      to see more details
    </p>
  <% end %>

  <!-- table info -->
  <% if @tables.any? %>
    <h1>Tables</h1>
    <table class="table table-vcenter">
      <thead>
        <tr>
          <th style="width: 25%">Name</th>
          <th style="width: 25%">Rows</th>
          <th>Indexes</th>
        </tr>
      </thead>
      <tbody>
        <% @tables.each do |table| %>
          <tr>
            <td><%= table %></td>
            <td><%= number_with_delimiter(@row_counts[table]) if @row_counts[table] %></td>
            <td>
              <% if @indexes_timeout %>
                Not available
              <% else %>
                <ul>
                  <% @indexes_by_table[table].to_a.sort_by { |i| [i[:primary] ? 0 : 1, i[:columns]] }.each do |i3| %>
                    <li>
                      <%= i3[:columns].join(", ") %><% if i3[:using] != "btree" %>
                      <%= i3[:using].to_s.upcase %><% end %>
                      <% if i3[:primary] %> PRIMARY<% elsif i3[:unique] %> UNIQUE<% end %>
                    </li>
                  <% end %>
                </ul>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
</div>
