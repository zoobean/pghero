<!DOCTYPE html>
<html data-bs-theme="dark">
  <head>
    <title><%= [@databases.size > 1 ? @database.name : "PgHero", @title].compact.join(" / ") %></title>

    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <%= favicon_link_tag "pghero/favicon.png" %>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/core@latest/dist/css/tabler.min.css">
    <% if defined?(Propshaft::Railtie) && Rails.application.assets.is_a?(Propshaft::Assembly) %>
      <%= stylesheet_link_tag "pghero/nouislider", "pghero/arduino-light", "pghero/application" %>
      <%= javascript_include_tag "pghero/jquery", "pghero/nouislider", "pghero/Chart.bundle", "pghero/chartkick", "pghero/highlight.min", "pghero/application", nonce: true %>
    <% else %>
      <%= stylesheet_link_tag "pghero/application" %>
      <%= javascript_include_tag "pghero/application", nonce: true %>
    <% end %>
  </head>
  <body class="theme-dark">
    <div class="page">
      <aside class="navbar navbar-vertical navbar-expand-lg navbar-dark">
        <div class="container-fluid">
          <h1 class="mb-4">
            <%= link_to(@databases.size > 1 ? @database.name : "PgHero", root_path, class: "navbar-brand navbar-brand-autodark text-reset text-decoration-none m-0") %>
          </h1>

          <div class="navbar-nav flex-column">
            <%= link_to "Overview", root_path, class: "nav-link #{controller.action_name == "index" ? "active" : ""}" %>
            <% if @system_stats_enabled %>
              <%= link_to "System", system_path, class: "nav-link #{controller.action_name == "system" ? "active" : ""}" %>
            <% end %>
            <% if @query_stats_enabled %>
              <%= link_to "Queries", queries_path, class: "nav-link #{controller.action_name == "queries" ? "active" : ""}" %>
            <% end %>
            <%= link_to "Space", space_path, class: "nav-link #{controller.action_name == "space" ? "active" : ""}" %>
            <%= link_to "Connections", connections_path, class: "nav-link #{controller.action_name == "connections" ? "active" : ""}" %>
            <%= link_to "Live Queries", live_queries_path, class: "nav-link #{controller.action_name == "live_queries" ? "active" : ""}" %>
            <% unless @database.replica? %>
              <%= link_to "Maintenance", maintenance_path, class: "nav-link #{controller.action_name == "maintenance" ? "active" : ""}" %>
            <% end %>
            <% if @explain_enabled %>
              <%= link_to "Explain", explain_path, class: "nav-link #{controller.action_name == "explain" ? "active" : ""}" %>
            <% end %>
            <%= link_to "Tune", tune_path, class: "nav-link #{controller.action_name == "tune" ? "active" : ""}" %>
          </div>

          <% if @databases.size > 1 %>
            <div class="small text-uppercase text-secondary fw-bold mt-4 mb-2">Databases</div>
            <div class="navbar-nav flex-column">
              <% @databases.each do |database| %>
                <%= link_to database.name, action_name == "show_query" ? root_path(database: database.id) : {database: database.id}, class: "nav-link #{(@database.id == database.id ? "active" : "")}" %>
              <% end %>
            </div>
          <% end %>
        </div>
      </aside>

      <div class="page-wrapper">
        <div class="page-header d-print-none">
          <div class="container-xl">
            <div class="d-flex align-items-center justify-content-between">
              <div>
                <div class="page-pretitle"><%= @databases.size > 1 ? @database.name : "Postgres Dashboard" %></div>
                <h2 class="page-title"><%= @title || (@databases.size > 1 ? @database.name : "PgHero") %></h2>
              </div>
            </div>
          </div>
        </div>

        <div class="page-body">
          <div class="container-xl">
            <div class="alert <%= alert ? "alert-danger" : "alert-info" %>" role="alert">
              <% if alert %>
                <%= alert %>
              <% elsif notice %>
                <%= notice %>
              <% elsif Rails.env.development? %>
                Do not use development information to make decisions about your production environment
              <% else %>
                <%= link_to "PgHero", root_path %>
              <% end %>
            </div>

            <%= yield %>
          </div>
        </div>
      </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/@tabler/core@latest/dist/js/tabler.min.js" defer></script>
  </body>
</html>
